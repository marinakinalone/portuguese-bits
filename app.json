{
  "expo": {
    "name": "portuguese-bits",
    "slug": "portuguese-bits",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "myapp",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.portuguesebits.app"
    },
    "android": {
      "package": "com.portuguesebits.app",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      }
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      [
        "expo-font",
        {
          "fonts": [
            "./assets/fonts/LatoRegular.ttf",
            "./assets/fonts/UchenRegular.ttf"
          ]
        }
      ],
      "./plugins/withRemovePushEntitlement.js",
      "./plugins/withPatchExpoModulesJsiDate.js"
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
